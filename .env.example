# =====================================================================
# Корневой .env — переменные для docker-compose.prod.yml
# Создайте .env (без .example) и заполните реальными значениями.
# Этот файл НЕ содержит секретов приложения (они в backend/.env).
#
# Секреты приложения (SMTP, API-ключи, ADMIN_API_KEY) — в backend/.env
# (см. backend/.env.example).
# =====================================================================

# Пароль PostgreSQL-пользователя `uute`.
# Должен совпадать с паролем в DATABASE_URL в backend/.env.
# Пример: postgresql+asyncpg://uute:<POSTGRES_PASSWORD>@postgres:5432/uute_db
POSTGRES_PASSWORD=
