# PostgreSQL
DATABASE_URL=postgresql+asyncpg://uute:uute_password@localhost:5432/uute_db

# Redis (для Celery)
REDIS_URL=redis://localhost:6379/0

# Файловое хранилище
UPLOAD_DIR=/var/uute-service/uploads

# SMTP
SMTP_HOST=smtp.yourdomain.ru
SMTP_PORT=465
SMTP_USER=noreply@yourdomain.ru
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=noreply@yourdomain.ru
SMTP_FROM_NAME=УУТЭ Проектировщик
SMTP_USE_SSL=true

# Приложение
APP_BASE_URL=https://yourdomain.ru
MAX_RETRY_COUNT=3

# Авторизация админки
ADMIN_API_KEY=change-me-in-production

# Уведомления инженеру
ADMIN_EMAIL=admin@yourdomain.ru

# LLM (OpenRouter — openrouter.ai)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=google/gemini-2.5-flash

# Реквизиты компании (для договоров и счетов)
COMPANY_FULL_NAME=ИП Иванов Иван Иванович
COMPANY_INN=000000000000
COMPANY_OGRN=000000000000000
COMPANY_ADDRESS=г. Москва, ул. Примерная, д. 1
COMPANY_BANK_NAME=ПАО Сбербанк
COMPANY_BIK=044525225
COMPANY_CORR_ACCOUNT=30101810400000000225
COMPANY_SETTLEMENT_ACCOUNT=40802810000000000000
COMPANY_DIRECTOR_NAME=Иванов Иван Иванович
COMPANY_DIRECTOR_POSITION=Индивидуальный предприниматель

# YooKassa (заполнить при реализации онлайн-оплаты)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
