# =====================================================================
# УУТЭ Проектировщик — пример .env
# Поля, помеченные [REQUIRED], обязательны: без них приложение упадёт
# на старте (валидация Pydantic Settings).
# =====================================================================

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://uute:uute_password@localhost:5432/uute_db

# Redis (для Celery)
REDIS_URL=redis://localhost:6379/0

# Файловое хранилище
UPLOAD_DIR=/var/uute-service/uploads

# SMTP
SMTP_HOST=smtp.yourdomain.ru
SMTP_PORT=465
SMTP_USER=noreply@yourdomain.ru
# [REQUIRED] Пароль SMTP. Без него `Settings()` упадёт при импорте.
SMTP_PASSWORD=
SMTP_FROM=noreply@yourdomain.ru
SMTP_FROM_NAME=УУТЭ Проектировщик
SMTP_USE_SSL=true

# Приложение
APP_BASE_URL=https://yourdomain.ru
MAX_RETRY_COUNT=3

# CORS — JSON-список разрешённых origin-ов (Pydantic v2 парсит JSON из ENV).
# Прод: только домен лендинга. Dev: добавить http://localhost:5173 для Vite и
# http://localhost:8000 для прямого обращения к FastAPI.
CORS_ORIGINS=["https://constructproject.ru"]

# [REQUIRED] Ключ админки (≥16 символов). НИКОГДА не коммитить!
# Можно сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=

# Уведомления инженеру
ADMIN_EMAIL=admin@yourdomain.ru

# LLM (OpenRouter — openrouter.ai)
# [REQUIRED] Без ключа парсинг ТУ через OpenRouter невозможен.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash

# Реквизиты компании (для договоров и счетов).
# Используются как дефолты в Settings; здесь оставлены для удобства dev-окружения.
COMPANY_FULL_NAME=ИП Анищенко Сергей Сергеевич
COMPANY_INN=280103456296
COMPANY_OGRN=305280120300026
COMPANY_ADDRESS=675000, Амурская область, г. Благовещенск, ул. Нагорная, 17-18
COMPANY_BANK_NAME=Филиал «Центральный» Банка ВТБ (ПАО)
COMPANY_BIK=044525411
COMPANY_CORR_ACCOUNT=30101810145250000411
COMPANY_SETTLEMENT_ACCOUNT=40802810709560000734
COMPANY_DIRECTOR_NAME=Анищенко Сергей Сергеевич
COMPANY_DIRECTOR_POSITION=Индивидуальный предприниматель

# YooKassa (заполнить при реализации онлайн-оплаты)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
