  ],
  "auto_rules": {
    "calculate_gdog": "G = Q*1000/(t1-t2), где Q из heat_loads.total_load, t1/t2 из coolant",
    "derive_si": "Закрытая система → '0'; открытая → '1'; из connection.system_type",
    "derive_ft": "SI=0→'1'; SI=1,2→'2'; SI=3,4→'3'",
    "map_tu_pressure_supply": "coolant.supply_pressure_kgcm2",
    "map_tu_pressure_return": "coolant.return_pressure_kgcm2",
    "map_tu_supply_temp": "coolant.supply_temp",
    "map_tu_return_temp": "coolant.return_temp",
    "derive_ht": "metering.temp_sensor_model: КТСН→'0' (100П); Pt100→'1'; 100М→'2'",
    "map_survey_tcw": "survey_data.tcw если есть"
  }
